---
import type { CollectionEntry } from 'astro:content'
import BaseLayout from './BaseLayout.astro'
import TagPill from '../components/TagPill.astro'
import { formatDate } from '../utils/content'
import { getLocale, t } from '../i18n/t'

interface Props {
  entry: CollectionEntry<'project'>
  fallback?: boolean
}

const { entry, fallback = false } = Astro.props
const locale = getLocale(Astro.url.pathname)
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  ogImage={entry.data.thumbnail.src}
>
  <article>
    <header class="mb-10">
      <div
        class="mb-6 aspect-video w-full overflow-hidden rounded-2xl border"
        style="border-color: rgb(var(--color-border-rgb));"
      >
        <img
          src={entry.data.thumbnail.src}
          alt={entry.data.thumbnail.alt}
          class="h-full w-full object-cover"
          decoding="async"
        />
      </div>
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">{entry.data.title}</h1>
      <p class="mt-3 text-base" style="color: rgb(var(--color-muted-rgb));">
        {entry.data.description}
      </p>
      <div
        class="mt-4 flex flex-wrap items-center gap-3 text-sm"
        style="color: rgb(var(--color-muted-rgb));"
      >
        <time datetime={entry.data.date.toISOString()}>
          {formatDate(entry.data.date, locale)}
        </time>
        {
          entry.data.tags.length > 0 && (
            <>
              <span>•</span>
              <span class="flex flex-wrap gap-1.5">
                {entry.data.tags.map((tag) => (
                  <TagPill label={tag} />
                ))}
              </span>
            </>
          )
        }
      </div>
      {
        entry.data.links.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-2">
            {entry.data.links.map((link) => (
              <a
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1 rounded-full border px-3 py-1 text-sm transition-colors hover:border-[rgb(var(--color-accent-rgb))] hover:text-[rgb(var(--color-accent-rgb))]"
                style="border-color: rgb(var(--color-border-rgb));"
              >
                {link.label} →
              </a>
            ))}
          </div>
        )
      }
      {
        fallback && (
          <p
            class="mt-6 rounded-lg border px-4 py-2 text-sm"
            style="border-color: rgb(var(--color-border-rgb)); color: rgb(var(--color-muted-rgb));"
          >
            {t(locale, 'projects.fallbackNotice')}
          </p>
        )
      }
    </header>

    <div class="prose max-w-none">
      <slot />
    </div>
  </article>
</BaseLayout>
