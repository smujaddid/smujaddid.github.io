---
import BaseLayout from '../../../layouts/BaseLayout.astro'
import ProjectCard from '../../../components/ProjectCard.astro'
import { getProjects } from '../../../utils/content'
import { getLocale, t } from '../../../i18n/t'

const locale = getLocale(Astro.url.pathname)
const projects = await getProjects(locale)
---

<BaseLayout title={t(locale, 'projects.title')} description={t(locale, 'projects.subtitle')}>
  <header class="mb-10">
    <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">{t(locale, 'projects.title')}</h1>
    <p class="mt-3 text-base" style="color: rgb(var(--color-muted-rgb));">
      {t(locale, 'projects.subtitle')}
    </p>
  </header>

  {
    projects.length === 0 ? (
      <p style="color: rgb(var(--color-muted-rgb));">{t(locale, 'projects.empty')}</p>
    ) : (
      <ul class="grid grid-cols-1 gap-5 sm:grid-cols-2">
        {projects.map((entry) => (
          <li>
            <ProjectCard entry={entry} />
          </li>
        ))}
      </ul>
    )
  }
</BaseLayout>
