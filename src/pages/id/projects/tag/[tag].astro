---
import BaseLayout from '../../../../layouts/BaseLayout.astro'
import ProjectCard from '../../../../components/ProjectCard.astro'
import { getProjects, getProjectsByTag } from '../../../../utils/content'
import { getLocale, t } from '../../../../i18n/t'

export async function getStaticPaths() {
  const projects = await getProjects('id')
  const allTags = new Set<string>()
  projects.forEach((project) => {
    project.data.tags.forEach((tag) => {
      allTags.add(tag.replace(/\s+/g, '-'))
    })
  })
  return Array.from(allTags).map((tag) => ({
    params: { tag },
  }))
}

const { tag } = Astro.params
const locale = getLocale(Astro.url.pathname)
const projects = await getProjectsByTag(locale, tag)
const tagLabel = tag.replace(/-/g, ' ')
---

<BaseLayout title={`${tagLabel}`} description={`Projects tagged with "${tagLabel}"`}>
  <header class="mb-10">
    <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">#{tagLabel}</h1>
    <p class="mt-3 text-base" style="color: rgb(var(--color-muted-rgb));">
      {t(locale, 'projects.subtitle')}
    </p>
  </header>

  {
    projects.length === 0 ? (
      <p style="color: rgb(var(--color-muted-rgb));">{t(locale, 'projects.empty')}</p>
    ) : (
      <ul class="grid grid-cols-1 gap-4 sm:grid-cols-2">
        {projects.map((entry) => (
          <li>
            <ProjectCard entry={entry} />
          </li>
        ))}
      </ul>
    )
  }
</BaseLayout>
