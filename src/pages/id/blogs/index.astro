---
import BaseLayout from '../../../layouts/BaseLayout.astro'
import PostCard from '../../../components/PostCard.astro'
import { getBlogs } from '../../../utils/content'
import { getLocale, t } from '../../../i18n/t'

const locale = getLocale(Astro.url.pathname)
const posts = await getBlogs(locale)
---

<BaseLayout title={t(locale, 'blogs.title')} description={t(locale, 'blogs.subtitle')}>
  <header class="mb-10">
    <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">{t(locale, 'blogs.title')}</h1>
    <p class="mt-3 text-base" style="color: rgb(var(--color-muted-rgb));">
      {t(locale, 'blogs.subtitle')}
    </p>
  </header>

  {
    posts.length === 0 ? (
      <p style="color: rgb(var(--color-muted-rgb));">{t(locale, 'blogs.empty')}</p>
    ) : (
      <ul class="flex flex-col gap-4">
        {posts.map((entry) => (
          <li>
            <PostCard entry={entry} />
          </li>
        ))}
      </ul>
    )
  }
</BaseLayout>
