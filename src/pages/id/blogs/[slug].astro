---
import { render } from 'astro:content'
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro'
import { getBlogs, toSlug } from '../../../utils/content'

export async function getStaticPaths() {
  const posts = await getBlogs('id')
  return posts.map((entry, i) => ({
    params: { slug: toSlug(entry) },
    props: {
      entry,
      prev: posts[i + 1] ?? null,
      next: posts[i - 1] ?? null,
    },
  }))
}

const { entry, prev, next } = Astro.props
const { Content } = await render(entry)
---

<BlogPostLayout entry={entry} body={entry.body} prev={prev} next={next}>
  <Content />
</BlogPostLayout>
