---
import BaseLayout from '../../layouts/BaseLayout.astro'
import SocialLinks from '../../components/SocialLinks.astro'
import { site } from '../../config/site'
import { getLocale, t } from '../../i18n/t'

const locale = getLocale(Astro.url.pathname)
---

<BaseLayout title={t(locale, 'contact.title')} description={t(locale, 'contact.subtitle')}>
  <header class="mb-10 text-center">
    <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">{t(locale, 'contact.title')}</h1>
    <p class="mx-auto mt-3 max-w-xl text-base" style="color: rgb(var(--color-muted-rgb));">
      {t(locale, 'contact.subtitle')}
    </p>
  </header>

  <section class="mb-10">
    <div
      class="flex flex-col items-center gap-4 rounded-2xl border px-6 py-10 text-center"
      style="border-color: rgb(var(--color-border-rgb)); background: rgb(var(--color-surface-rgb) / 0.5);"
    >
      <a
        href={`mailto:${site.email}`}
        class="font-serif text-2xl font-semibold tracking-tight break-all transition-colors hover:text-[rgb(var(--color-accent-rgb))] sm:text-3xl"
      >
        {site.email}
      </a>
      <button
        type="button"
        id="copy-email"
        data-email={site.email}
        data-label-copy={t(locale, 'contact.copy')}
        data-label-copied={t(locale, 'contact.copied')}
        class="inline-flex items-center gap-2 rounded-full border px-4 py-1.5 text-sm transition-colors hover:border-[rgb(var(--color-accent-rgb))] hover:text-[rgb(var(--color-accent-rgb))]"
        style="border-color: rgb(var(--color-border-rgb));"
      >
        {t(locale, 'contact.copy')}
      </button>
    </div>
  </section>

  <section>
    <SocialLinks />
  </section>
</BaseLayout>

<script>
  const btn = document.getElementById('copy-email')
  if (btn instanceof HTMLButtonElement) {
    const email = btn.dataset.email ?? ''
    const labelCopy = btn.dataset.labelCopy ?? 'Copy'
    const labelCopied = btn.dataset.labelCopied ?? 'Copied'
    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(email)
        btn.textContent = labelCopied
        setTimeout(() => {
          btn.textContent = labelCopy
        }, 1500)
      } catch {
        /* ignore */
      }
    })
  }
</script>
