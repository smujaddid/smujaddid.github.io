---
import BaseLayout from '../layouts/BaseLayout.astro'
import { getLocale, t, localizedPath } from '../i18n/t'
const locale = getLocale(Astro.url.pathname)
---

<BaseLayout title={t(locale, '404.title')}>
  <section class="flex flex-col items-center text-center">
    <p class="font-serif text-6xl font-bold" style="color: rgb(var(--color-accent-rgb));">404</p>
    <h1 class="mt-4 text-2xl font-semibold tracking-tight">{t(locale, '404.title')}</h1>
    <p class="mt-2 text-base" style="color: rgb(var(--color-muted-rgb));">
      {t(locale, '404.description')}
    </p>
    <a
      href={localizedPath(locale, '/')}
      class="mt-6 inline-flex items-center gap-2 rounded-full px-5 py-2 text-sm font-semibold"
      style="background: rgb(var(--color-accent-rgb)); color: rgb(var(--color-bg-rgb));"
    >
      ← {t(locale, '404.home')}
    </a>
  </section>
</BaseLayout>
