---
import BaseLayout from '../../../layouts/BaseLayout.astro'
import PostCard from '../../../components/PostCard.astro'
import { getBlogs, getBlogsByTag } from '../../../utils/content'
import { getLocale, t } from '../../../i18n/t'

export async function getStaticPaths() {
  const posts = await getBlogs('en')
  const allTags = new Set<string>()
  posts.forEach((post) => {
    post.data.tags.forEach((tag) => {
      allTags.add(tag.replace(/\s+/g, '-'))
    })
  })
  return Array.from(allTags).map((tag) => ({
    params: { tag },
  }))
}

const { tag } = Astro.params
const locale = getLocale(Astro.url.pathname)
const posts = await getBlogsByTag(locale, tag)
const tagLabel = tag.replace(/-/g, ' ')
---

<BaseLayout title={`${tagLabel}`} description={`Blog posts tagged with "${tagLabel}"`}>
  <header class="mb-10">
    <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">#{tagLabel}</h1>
    <p class="mt-3 text-base" style="color: rgb(var(--color-muted-rgb));">
      {t(locale, 'blogs.tagDescription', { tag: tagLabel })}
    </p>
  </header>

  {
    posts.length === 0 ? (
      <p style="color: rgb(var(--color-muted-rgb));">{t(locale, 'blogs.tagEmpty')}</p>
    ) : (
      <ul class="flex flex-col gap-4">
        {posts.map((entry) => (
          <li>
            <PostCard entry={entry} />
          </li>
        ))}
      </ul>
    )
  }
</BaseLayout>
