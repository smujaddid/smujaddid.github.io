---
import { Icon } from 'astro-icon/components'
import { site } from '../config/site'

interface Props {
  compact?: boolean
}
const { compact = false } = Astro.props

const links = [
  { label: 'LinkedIn', href: site.social.linkedin, icon: 'simple-icons:linkedin' },
  { label: 'Twitter', href: site.social.twitter, icon: 'simple-icons:x' },
  { label: 'GitHub', href: site.social.github, icon: 'simple-icons:github' },
  { label: 'GitLab', href: site.social.gitlab, icon: 'simple-icons:gitlab' },
  { label: 'Email', href: `mailto:${site.email}`, icon: 'lucide:mail' },
]
---

{
  compact ? (
    <ul class="flex items-center gap-2">
      {links.map(({ label, href, icon }) => (
        <li>
          <a
            href={href}
            target={href.startsWith('mailto:') ? undefined : '_blank'}
            rel={href.startsWith('mailto:') ? undefined : 'noopener noreferrer'}
            class="grid size-8 place-items-center rounded-full transition-colors hover:text-[rgb(var(--color-accent-rgb))]"
            aria-label={label}
            title={label}
          >
            <Icon name={icon} class="size-4" />
          </a>
        </li>
      ))}
    </ul>
  ) : (
    <ul class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      {links.map(({ label, href, icon }) => (
        <li>
          <a
            href={href}
            target={href.startsWith('mailto:') ? undefined : '_blank'}
            rel={href.startsWith('mailto:') ? undefined : 'noopener noreferrer'}
            class="flex items-center gap-3 rounded-xl border px-4 py-3 transition-colors hover:border-[rgb(var(--color-accent-rgb))] hover:text-[rgb(var(--color-accent-rgb))]"
            style="border-color: rgb(var(--color-border-rgb)); background: rgb(var(--color-surface-rgb) / 0.5);"
          >
            <Icon name={icon} class="size-5" />
            <div class="flex flex-col">
              <span class="text-sm font-semibold">{label}</span>
              <span class="text-xs" style="color: rgb(var(--color-muted-rgb));">
                {href.startsWith('mailto:') ? href.replace('mailto:', '') : new URL(href).host}
              </span>
            </div>
          </a>
        </li>
      ))}
    </ul>
  )
}
