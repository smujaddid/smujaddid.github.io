---
interface Props {
  rating: 1 | 2 | 3
  size?: string
}
const { rating, size = 'size-3' } = Astro.props
---

<span class="flex items-center gap-0.5">
  {
    [1, 2, 3].map((i) =>
      rating >= i ? (
        <svg
          class={size}
          viewBox="0 0 24 24"
          fill="currentColor"
          stroke="currentColor"
          stroke-width="2"
          style="color: rgb(var(--color-accent-rgb));"
        >
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
        </svg>
      ) : (
        <svg
          class={size}
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          style="color: rgb(var(--color-muted-rgb));"
        >
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
        </svg>
      ),
    )
  }
</span>
