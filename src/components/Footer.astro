---
import SocialLinks from './SocialLinks.astro'
import { site } from '../config/site'
import { getLocale, t } from '../i18n/t'
const locale = getLocale(Astro.url.pathname)
const year = new Date().getFullYear()
---

<footer
  class="mx-auto w-full max-w-3xl px-6 pt-6 pb-10 text-sm sm:px-8"
  style="color: rgb(var(--color-muted-rgb));"
>
  <div
    class="flex flex-col items-center justify-between gap-4 border-t pt-6 sm:flex-row"
    style="border-color: rgb(var(--color-border-rgb));"
  >
    <p>© {year} {site.name}. {t(locale, 'footer.rights')}</p>
    <SocialLinks compact />
  </div>
</footer>
