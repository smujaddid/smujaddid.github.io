---
interface Image {
  src: string
  alt: string
  caption?: string
}
interface Props {
  images: Image[]
}
const { images } = Astro.props
---

<figure class="not-prose my-8 grid grid-cols-1 gap-4 sm:grid-cols-2">
  {
    images.map((image) => (
      <figure
        class="overflow-hidden rounded-xl border"
        style="border-color: rgb(var(--color-border-rgb)); background: rgb(var(--color-surface-rgb) / 0.5);"
      >
        <img
          src={image.src}
          alt={image.alt}
          class="aspect-video w-full object-cover"
          loading="lazy"
          decoding="async"
        />
        {image.caption && (
          <figcaption
            class="border-t px-3 py-2 text-xs"
            style="border-color: rgb(var(--color-border-rgb)); color: rgb(var(--color-muted-rgb));"
          >
            {image.caption}
          </figcaption>
        )}
      </figure>
    ))
  }
</figure>
